# Copy to .env for local development. Do not commit real secrets.

# Required for scraping and GraphQL enrichment.
GITHUB_TOKEN=ghp_your_token_here

# Optional. Required only for `github-bounty-scraper vibe-check`.
GEMINI_API_KEY=your_gemini_key_here

# Optional. The CLI defaults to bounty_stats.db when omitted.
# DB_PATH=bounty_stats.db
