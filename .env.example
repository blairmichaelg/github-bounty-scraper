# GitHub Personal Access Token (required)
GITHUB_TOKEN=your_github_token_here

# Gemini API Key for vibe scoring (optional but recommended)
GEMINI_API_KEY=your_gemini_api_key_here
# OR
# GOOGLE_API_KEY=your_google_api_key_here

# Path to SQLite database (optional, default: bounty_cache.db)
DB_PATH=bounty_cache.db

# Path to raw candidates log (optional)
RAW_CANDIDATES_FILE=exploration_raw.jsonl
